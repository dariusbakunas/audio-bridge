    "test:e2e:chromium:ui": "E2E_STATE_KEY=chromium-ui E2E_HUB_PORT=18081 E2E_BASE_URL=http://127.0.0.1:18081 playwright test --project=chromium --ui",
    "test:e2e:firefox:ui": "E2E_STATE_KEY=firefox-ui E2E_HUB_PORT=18082 E2E_BASE_URL=http://127.0.0.1:18082 playwright test --project=firefox --ui",
