    "test:e2e:webkit": "E2E_STATE_KEY=webkit E2E_HUB_PORT=18083 E2E_BASE_URL=http://127.0.0.1:18083 playwright test --project=webkit",
    "test:e2e:chromium:headed": "E2E_STATE_KEY=chromium-headed E2E_HUB_PORT=18081 E2E_BASE_URL=http://127.0.0.1:18081 playwright test --project=chromium --headed",
    "test:e2e:firefox:headed": "E2E_STATE_KEY=firefox-headed E2E_HUB_PORT=18082 E2E_BASE_URL=http://127.0.0.1:18082 playwright test --project=firefox --headed",
